{
  "name": "pagup",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "export ANDROID_HOME=\"$HOME/Library/Android/sdk\" && export JAVA_HOME=\"/opt/homebrew/opt/openjdk@17\" && npx jetify && expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "audit:student": "npx impeccable detect src/screens/student && npx eslint --no-eslintrc -c .eslintrc.a11y.json --ext .ts,.tsx src/screens/student",
    "audit:tutor": "npx impeccable detect src/screens/tutor"
  },
  "jest": {
    "preset": "jest-expo/node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "\\.worktrees/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|lucide-react-native|@react-native-ml-kit|@react-native-voice|react-native-reanimated|react-native-gesture-handler|react-native-qrcode-svg)/)"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.8.10",
    "@supabase/supabase-js": "^2.104.1",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-speech-recognition": "^3.1.3",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.9.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "2.31.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.3.0",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "^0.8.1",
    "react-native-worklets-core": "^1.6.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "babel-preset-expo": "^55.0.18",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "impeccable": "^2.1.8",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "jetifier": "^2.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
